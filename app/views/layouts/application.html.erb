<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Jotted" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Jotted">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="<%= ENV.fetch("ASSET_PREFIX", "") %>/manifest.json">

    <link rel="icon" href="<%= ENV.fetch("ASSET_PREFIX", "") %>/icon-32.png" type="image/png" sizes="32x32">
    <link rel="icon" href="<%= ENV.fetch("ASSET_PREFIX", "") %>/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="<%= ENV.fetch("ASSET_PREFIX", "") %>/icon-180.png">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <%= yield %>

    <div data-controller="pwa-install">
      <div data-pwa-install-target="banner" class="hidden">
        <div class="install-banner">
          <span class="text-sm font-medium text-jb-text">Install Jotted</span>
          <button data-action="pwa-install#install" class="btn-jb-accent text-xs px-3 py-[5px]">Install</button>
          <button data-action="pwa-install#dismiss" class="install-banner-close">&times;</button>
        </div>
      </div>
    </div>

    <script>
      if ("serviceWorker" in navigator) {
        navigator.serviceWorker.register("<%= ENV.fetch("ASSET_PREFIX", "") %>/service-worker");
      }
    </script>
  </body>
</html>
