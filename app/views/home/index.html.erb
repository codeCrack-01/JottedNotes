<div class="container-fluid p-0" data-controller="notes">
  <button data-action="click->notes#toggleSidebar"
          class="btn sidebar-toggle-btn d-md-none position-fixed top-0 start-0 mt-3 ms-3"
          type="button"
          style="z-index: 1060;">
    <i class="bi bi-list fs-4"></i>
  </button>
<div class="container-fluid p-0" data-controller="notes">
