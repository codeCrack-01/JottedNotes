<div class="container-fluid p-0" data-controller="notes">
  <div class="row g-0">

    <%= render "home/sidebar" %>

    <div class="col-md-9 ide-editor d-flex flex-column p-4">

      <%= render "home/editor_canvas" %>

      <div data-notes-target="emptyState" class="m-auto text-center" style="max-width: 400px;">
        <div class="text-muted mb-2 font-monospace" style="font-size: 0.85rem;">JetBrains Notes v2026.1</div>
        <p class="small" style="color: var(--jb-text-muted);">Select an architectural item from the tree projection or click the initialization button to start modifying a document node.</p>
      </div>

    </div>

  </div>
</div>