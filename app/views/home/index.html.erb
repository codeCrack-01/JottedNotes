<div class="min-h-screen bg-jb-bg" data-controller="notes">
  <button data-action="click->notes#toggleSidebar"
          class="sidebar-toggle-btn fixed top-3 left-3 z-50 lg:hidden flex items-center justify-center"
          type="button"
          aria-label="Toggle sidebar">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor">
      <path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/>
    </svg>
  </button>

  <div class="flex min-h-screen">
    <%= render "home/sidebar" %>

    <div class="flex-1 flex flex-col p-3 lg:p-4 pt-14 lg:pt-4 min-w-0">
      <div class="island-panel flex-1 flex flex-col p-4 lg:p-6 overflow-hidden">
        <%= render "home/editor_canvas" %>

        <div data-notes-target="emptyState" class="flex-1 flex items-center justify-center">
          <div class="text-center max-w-sm">
            <div class="text-jb-muted mb-2 font-mono text-sm">JetBrains Notes v2026.1</div>
            <p class="text-xs text-jb-muted leading-relaxed">Select an item from the project tree or create a new note to start editing.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
