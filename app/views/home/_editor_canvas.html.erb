<div data-notes-target="editor" class="hidden flex-1 flex flex-col min-h-0">
  <input type="hidden" data-notes-target="id">

  <div class="pb-3 mb-3 border-b border-jb-border flex-shrink-0">
    <input type="text" data-notes-target="title" data-action="input->notes#markDirty" class="jb-input text-lg md:text-xl font-bold" placeholder="Untitled_Note.md">
  </div>

  <div class="flex-1 relative flex items-stretch min-h-0 gap-3">
    <div class="relative flex flex-col flex-1 min-w-0">
      <input type="hidden" id="note_content_hidden" data-notes-target="content">

      <trix-editor input="note_content_hidden"
                   class="trix-content flex-1"
                   placeholder="// Start writing..."
                   data-action="trix-change->notes#updateWordCount trix-initialize->notes#onTrixInit"></trix-editor>

      <div class="flex items-center justify-between pt-2 mt-2 border-t border-jb-border flex-shrink-0">
        <div data-notes-target="wordCount" class="status-pill relative bottom-auto right-auto">
          0 words · 0 chars
        </div>
      </div>
    </div>

    <div class="relative flex-shrink-0" style="width: 52px;">
      <div class="dock-column">
        <button class="read-only-toggle"
                data-notes-target="readOnlyToggle"
                data-action="click->notes#toggleReadOnly"
                type="button"
                title="Switch to edit mode">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="3"/>
            <path d="M15.5 5.5a2.12 2.12 0 0 1 3 3L7 20l-4 1 1-4 11.5-11.5z"/>
          </svg>
        </button>
        <div data-notes-target="dockPanel">
          <%= render "home/floating_dock" %>
        </div>
      </div>
    </div>
  </div>

  <div data-notes-target="editorActions" class="flex items-center gap-2 pt-3 mt-3 border-t border-jb-border flex-shrink-0">
    <button class="btn-jb-success" data-notes-target="saveIndicator" data-action="click->notes#saveNote">Saved</button>
    <button class="btn-jb-ghost" data-action="click->notes#deleteNote">Delete</button>
  </div>
</div>

<div data-notes-target="confirmDialog" class="modal-overlay" data-action="click->notes#confirmNo">
  <div class="modal-island" data-action="click->stopPropagation">
    <div class="modal-icon">
      <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="3 6 5 6 21 6"/>
        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
        <line x1="10" y1="11" x2="10" y2="17"/>
        <line x1="14" y1="11" x2="14" y2="17"/>
      </svg>
    </div>
    <h3 class="modal-title">Delete Note</h3>
    <p data-notes-target="confirmMessage" class="modal-message">Are you sure you want to delete this note? This cannot be undone.</p>
    <div class="modal-actions">
      <button class="btn-jb-ghost" data-action="click->notes#confirmNo">Cancel</button>
      <button class="btn-jb-danger" data-action="click->notes#confirmYes">Delete</button>
    </div>
  </div>
</div>
