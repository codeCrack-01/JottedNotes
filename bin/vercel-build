#!/bin/bash
set -e

echo "==> Installing Ruby dependencies..."
bundle install

echo "==> Installing JavaScript dependencies..."
yarn install

echo "==> Compiling Bootstrap CSS..."
yarn build:css:compile
yarn build:css:prefix

echo "==> Precompiling Rails assets..."
export RAILS_ENV=production
export SECRET_KEY_BASE_DUMMY=1
bundle exec rails assets:precompile

echo "==> Exporting static pages..."
bundle exec rails vercel:export

echo ""
echo "  Done! public/ directory is ready for Vercel deployment."
echo ""
echo "  Next steps:"
echo "    1. npx vercel --prod"
echo "       or"
echo "    2. git add public/ && git push (if using Vercel Git integration with pre-built assets)"
echo ""
